{
  "name": "kebab-events",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicación interna para coordinación de eventos, clientes y trabajadores.",
  "scripts": {
    "install:all": "python3 --version",
    "db:migrate": "python3 backend/app.py migrate",
    "db:seed": "python3 backend/app.py seed",
    "db:reset": "python3 backend/app.py reset",
    "dev": "python3 backend/app.py serve",
    "dev:backend": "python3 backend/app.py serve",
    "dev:frontend": "python3 backend/app.py serve",
    "start": "python3 backend/app.py serve",
    "build": "python3 -m py_compile backend/app.py"
  }
}
